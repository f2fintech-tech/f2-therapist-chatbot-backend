# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
# Values: development, staging, production

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# For production, explicitly set your frontend URL(s)
# Example: https://app.example.com,https://www.example.com

# ==================== DATABASE ====================
DATABASE_URL=postgresql://username:password@localhost:5432/financial_therapist
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For local development with Docker Compose: postgresql://postgres:postgres@db:5432/financial_therapist

# ==================== ANTHROPIC API ====================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Get your key from: https://console.anthropic.com/

# ==================== PINECONE VECTOR DB ====================
PINECONE_API_KEY=your_pinecone_api_key_here
# Optional - for vector embeddings
# Get your key from: https://www.pinecone.io/

# ==================== LOGGING ====================
# Set to true for detailed SQL query logging in development
SQL_ECHO=false