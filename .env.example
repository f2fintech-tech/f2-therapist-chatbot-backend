# ==================== ENVIRONMENT ====================
ENVIRONMENT=development
# Values: development, staging, production

# ==================== APPLICATION ====================
APP_ENV=development

# ==================== SERVER ====================
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
# For production, explicitly set your frontend URL(s)
# Example: https://app.example.com,https://www.example.com

# Optional: comma-separated hostnames for production host validation
ALLOWED_HOSTS=localhost,127.0.0.1

# Additional CORS alias used by some workflows/configurations
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==================== MONITORING & ALERTS ====================
# Optional Slack incoming webhook for alert notifications
SLACK_WEBHOOK_URL=

# ==================== GOOGLE GEMINI API ====================
GEMINI_API_KEY=your_google_gemini_api_key_here
# Get your key from: https://makersuite.google.com/app/apikey

# ==================== PINECONE VECTOR DB ====================
PINECONE_API_KEY=your_pinecone_api_key_here
# Optional - for vector embeddings
# Get your key from: https://www.pinecone.io/

# ==================== AWS S3 ====================
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name_here
# Used for storing and syncing knowledge-base files

# ==================== DATABASE ====================
DATABASE_URL=postgresql://username:password@localhost:5432/financial_therapist
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
# For local development with Docker Compose: postgresql://postgres:postgres@db:5432/financial_therapist

# Individual PostgreSQL connection parameters (alternative to DATABASE_URL)
DB_HOST=
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

# Local database credentials used by scripts and workflow examples
POSTGRES_USER=postgres
POSTGRES_DB=financial_therapist

# ==================== LOGGING ====================
# Set to true for detailed SQL query logging in development
SQL_ECHO=false
