{
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.11"
    }
  },
  "remoteEnv": {
    "AWS_ACCESS_KEY_ID": "${localEnv:AWS_ACCESS_KEY_ID}",
    "AWS_SECRET_ACCESS_KEY": "${localEnv:AWS_SECRET_ACCESS_KEY}",
    "AWS_REGION": "${localEnv:AWS_REGION:-ap-south-1}",
    "AWS_S3_BUCKET_NAME": "${localEnv:AWS_S3_BUCKET_NAME}",
    "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY}",
    "PINECONE_API_KEY": "${localEnv:PINECONE_API_KEY}",
    "PINECONE_INDEX_NAME": "${localEnv:PINECONE_INDEX_NAME}"
  },
  "postCreateCommand": "pip install -q -r requirements.txt 2>/dev/null || true",
  "postStartCommand": "bash .devcontainer/post-start.sh"
}